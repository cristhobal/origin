---
// LanguagesBar.astro — HUD telemetry strip for repo languages.

import { getTagIcon } from "@/shared/icons";

interface Props {
  languages: Record<string, number>;
}

const { languages } = Astro.props;

const total = Object.values(languages).reduce((s, b) => s + b, 0);

const stats = Object.entries(languages)
  .map(([name, bytes]) => ({
    name,
    bytes,
    pct: (bytes / total) * 100,
    icon: getTagIcon(name),
  }))
  .sort((a, b) => b.bytes - a.bytes);
---

<div class="flex items-center flex-wrap gap-1.5">
  {
    stats.map((l) => (
      <span class="inline-flex items-center gap-1.5 border border-stark-gold/30 bg-stark-gold/[0.06] px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-mono uppercase tracking-[0.12em] text-stark-gold/95">
        {l.icon && (
          <span class="[&>svg]:h-3 [&>svg]:w-3" set:html={l.icon} />
        )}
        <span>{l.name}</span>
        <span class="text-titanium/55">{l.pct.toFixed(0)}%</span>
      </span>
    ))
  }
</div>

<style>
  .text-stark-gold\/95 {
    color: rgba(255, 184, 0, 0.95);
  }
  .text-titanium\/55 {
    color: rgba(232, 232, 232, 0.6);
  }
  .border-stark-gold\/30 {
    border-color: rgba(255, 184, 0, 0.32);
  }
  .bg-stark-gold\/\[0\.06\] {
    background-color: rgba(255, 184, 0, 0.06);
  }
</style>
