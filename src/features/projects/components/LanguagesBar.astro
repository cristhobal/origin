---
// LanguagesBar.astro
// Muestra los lenguajes de un repo como badges compactos con SVG icons.
// Recibe el objeto { "TypeScript": 84123, "Astro": 40221, ... } que devuelve
// GET /repos/{owner}/{repo}/languages (bytes por lenguaje).

import { getTagIcon } from "@/shared/icons";

interface Props {
  languages: Record<string, number>;
}

const { languages } = Astro.props;

const total = Object.values(languages).reduce((s, b) => s + b, 0);

const stats = Object.entries(languages)
  .map(([name, bytes]) => ({
    name,
    bytes,
    pct: (bytes / total) * 100,
    icon: getTagIcon(name),
  }))
  .sort((a, b) => b.bytes - a.bytes);
---

<div class="flex items-center flex-wrap gap-1.5">
  {stats.slice(0, 4).map((l) => (
    <span class="inline-flex items-center gap-1.5 rounded-[2.5px] border border-neutral-300 bg-neutral-200/50 px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium dark:border-neutral-800 dark:bg-neutral-800/60 dark:text-neutral-300">
      {l.icon && <Fragment set:html={l.icon} />}
      <span>{l.name}</span>
    </span>
  ))}
</div>
