---
import "../styles/global.css";
import { BlurFade } from "@/shared/ui/blur-fade";
import Header from "@/shared/components/Header.astro";
import Footer from "@/shared/components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = "Cristhobal Canales",
  description = "Cristhobal Canales — Fullstack Web Developer from Chile. Building web systems for public institutions, modern UIs and custom FiveM scripts with Astro, React, TypeScript and Node.js.",
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteUrl = "https://www.cristhobal.cl";
const canonicalURL = new URL(canonicalPath, siteUrl).href;
const fullTitle =
  title === "Cristhobal Canales"
    ? title
    : `${title} – Cristhobal Canales · Fullstack Dev Chile`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.png" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#0a0e14" />

    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Cristhobal Canales" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta
      name="keywords"
      content="Cristhobal Canales, fullstack developer Chile, web developer Chile, Astro developer, React developer, TypeScript developer, Node.js developer, FiveM scripts, sistemas municipales Chile, portfolio desarrollador Chile"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Cristhobal Canales" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://www.cristhobal.cl/og.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Cristhobal Canales — Fullstack Web Developer from Chile"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.cristhobal.cl/og.png" />
    <meta
      name="twitter:image:alt"
      content="Cristhobal Canales — Fullstack Web Developer from Chile."
    />
  </head>

  <body class="min-h-screen flex flex-col relative">
    <!-- Decorative HUD sweep -->
    <div
      class="fixed inset-0 z-[1] pointer-events-none overflow-hidden mix-blend-screen"
      aria-hidden="true"
    >
      <div
        class="absolute inset-x-0 h-[120px] hud-sweep"
        style="background: linear-gradient(to bottom, transparent, rgba(0,229,255,0.07), transparent);"
      >
      </div>
    </div>

    <Header />

    <div
      class="max-w-5xl mx-auto flex flex-col flex-1 w-full px-4 sm:px-6 lg:px-4 pt-8 sm:pt-10 relative z-10"
    >
      <main class="flex-1 pb-4">
        <BlurFade
          client:load
          inView
          className="flex flex-col gap-6 sm:gap-8 md:gap-10"
        >
          <slot />
        </BlurFade>
      </main>
    </div>

    <Footer />
  </body>

  <script is:inline>
    document.documentElement.classList.add("dark");

    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll(".card").forEach((card) => {
        card.addEventListener("mousemove", (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty("--x", `${x}px`);
          card.style.setProperty("--y", `${y}px`);
        });
      });
    });
  </script>
</html>
