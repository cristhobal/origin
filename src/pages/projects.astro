---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects as staticProjects } from "@/features/projects/data";
import { GITHUB_USERNAME } from "@/shared/config/site";
import { fetchGitHubProjects, HIDDEN_REPOS } from "@/features/projects/services/github.service";
import { getTagIcon, scopeSvg } from "@/shared/icons";
import LanguagesBar from "@/features/projects/components/LanguagesBar.astro";
import { PrivateRepoPreview } from "@/features/projects/components/PrivateRepoPreview";

// 👇 Cache en el CDN de Vercel: la respuesta se sirve desde edge cache
//    durante 5 min (s-maxage=300). Despues de ese rato, el primer visitante
//    ve la version "stale" al instante mientras Vercel revalida en background
//    (stale-while-revalidate=86400 = hasta 24h).
//
//    Resultado: cambios en GitHub aparecen en <= ~5 min, sin que NADIE
//    espere por la API de GitHub. Ajusta s-maxage si quieres mas frescura
//    (ojo con el rate limit de GitHub: 5000 req/h con token).
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=300, stale-while-revalidate=86400",
);

// Trae repos de GitHub y combina con los proyectos estáticos
let ghProjects = [];
try {
  ghProjects = await fetchGitHubProjects(GITHUB_USERNAME);
} catch (e) {
  console.error("[projects.astro] No se pudieron cargar los repos de GitHub:", e);
}

// Ordena por fecha de creación (más nuevos primero). Así la posición no
// cambia cuando se actualiza un repo — solo cuando se crea uno nuevo.
const projects = [...staticProjects, ...ghProjects]
  .filter((p) => !HIDDEN_REPOS.includes(p.name))
  .sort(
    (a, b) =>
      new Date(b.createdAt ?? 0).getTime() -
      new Date(a.createdAt ?? 0).getTime(),
  );

---

<BaseLayout
  title="Projects"
  description="Projects by Cristhobal Canales — open-source and private work in Astro, React, TypeScript and Node.js. Includes reservation systems, administrative platforms and custom FiveM scripts."
  canonicalPath="/projects"
>

  <!-- Page header -->
  <div class="pb-5 sm:pb-7 border-b border-neutral-200 dark:border-neutral-800 fade-down-section" style="--delay: 0ms">
    <nav class="flex items-center gap-1.5 text-xs text-neutral-400 dark:text-neutral-600 mb-3 sm:mb-4 font-mono" aria-label="Breadcrumb">
      <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-400 transition-colors duration-150" aria-label="Home">~</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page" data-i18n="nav.projects">projects</span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-bold tracking-tight" data-i18n="projects.title">Projects</h1>
    <p class="mt-1.5 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed" data-i18n="projects.subtitle">
      A selection of projects I've built and contributed to over the years.
    </p>
  </div>

  <!-- Search -->
  <div class="relative fade-down-section" style="--delay: 100ms">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 dark:text-neutral-600 pointer-events-none"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="text"
      placeholder="Search projects…"
      data-i18n="projects.search"
      id="project-search"
      class="w-full rounded-[5px] border border-neutral-200 dark:border-neutral-800 bg-transparent pl-9 pr-4 py-2 text-sm placeholder:text-neutral-400 dark:placeholder:text-neutral-600 focus:outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition-colors"
    />
  </div>

  {projects.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-16 text-center fade-down-section" style="--delay: 200ms">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-3 text-neutral-300 dark:text-neutral-700">
        <path d="M3 3h18v18H3z" rx="2"/><path d="M9 9h6M9 13h4"/>
      </svg>
      <p class="text-sm font-medium text-neutral-500 dark:text-neutral-400">No projects found</p>
      <p class="mt-1 text-xs text-neutral-400 dark:text-neutral-600">Nothing here yet — check back soon.</p>
    </div>
  ) : (
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 fade-down-section" style="--delay: 200ms">
    {
      projects.map((project, projectIdx) => (
        <div class="card group relative rounded-[6px] p-px overflow-hidden border border-neutral-300 dark:border-neutral-800"
          data-search-name={project.name.toLowerCase()}
          data-search-desc={(project.description || "").toLowerCase()}
          data-search-tags={((project.languages ? Object.keys(project.languages).join(" ") : "") + " " + project.tags.map(t => t.name).join(" ")).toLowerCase()}
        >
          <div class="glow absolute inset-0 pointer-events-none"></div>
          <div class="relative flex flex-col h-full rounded-[5px] bg-white dark:bg-neutral-950 p-3 sm:p-4">
            <div class="flex flex-col space-y-3 h-full">

              <!-- Header -->
              <div class="flex w-full items-center justify-between">
                <div class="flex items-center space-x-2.5 min-w-0">
                    {project.logo && (
                      <img src={project.logo} alt={project.name} class="size-6 flex-shrink-0 object-contain" />
                  )}
                  {project.isPrivate && project.preview ? (
                    <PrivateRepoPreview
                      client:load
                      name={project.name}
                      previewUrl={project.preview}
                      href={project.href}
                    />
                  ) : project.href ? (
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noopener"
                      class="group/l flex items-center gap-1.5 font-medium relative min-w-0"
                    >
                      <span class="relative truncate">
                        {project.name}
                        <span class="absolute left-0 bottom-0 h-px w-0 bg-current opacity-30 transition-all duration-200 group-hover/l:w-full"></span>
                      </span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 opacity-50 transition-all duration-200 group-hover/l:translate-x-[1.5px] group-hover/l:opacity-100">
                        <path d="M7 7h10v10"></path>
                        <path d="M7 17 17 7"></path>
                      </svg>
                    </a>
                  ) : (
                    <p class="font-medium truncate">{project.name}</p>
                  )}
                </div>

                <div class="flex items-center gap-2 flex-shrink-0 ml-2">
                  {project.isPrivate ? (
                    <span class="cursor-default text-[10px] px-2 py-0.5 rounded border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 whitespace-nowrap">
                      Private
                    </span>
                  ) : (
                    <span class="cursor-default text-[10px] px-2 py-0.5 rounded border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 whitespace-nowrap">
                      Public
                    </span>
                  )}
                  <a
                    href={project.githubUrl || "#"}
                    target="_blank"
                    class:list={[
                      "transition-opacity",
                      !project.githubUrl
                        ? "pointer-events-none opacity-50 cursor-not-allowed"
                        : "opacity-70 hover:opacity-100",
                    ]}
                  >
                    <svg viewBox="0 0 256 250" fill="currentColor" width="20" height="16">
                      <path d="M128.001 0C57.317 0 0 57.307 0 128.001c0 56.554 36.676 104.535 87.535 121.46 6.397 1.185 8.746-2.777 8.746-6.158 0-3.052-.12-13.135-.174-23.83-35.61 7.742-43.124-15.103-43.124-15.103-5.823-14.795-14.213-18.73-14.213-18.73-11.613-7.944.876-7.78.876-7.78 12.853.902 19.621 13.19 19.621 13.19 11.417 19.568 29.945 13.911 37.249 10.64 1.149-8.272 4.466-13.92 8.127-17.116-28.431-3.236-58.318-14.212-58.318-63.258 0-13.975 5-25.394 13.188-34.358-1.329-3.224-5.71-16.242 1.24-33.874 0 0 10.749-3.44 35.21 13.121 10.21-2.836 21.16-4.258 32.038-4.307 10.878.049 21.837 1.47 32.066 4.307 24.431-16.56 35.165-13.12 35.165-13.12 6.967 17.63 2.584 30.65 1.255 33.873 8.207 8.964 13.173 20.383 13.173 34.358 0 49.163-29.944 59.988-58.447 63.157 4.591 3.972 8.682 11.762 8.682 23.704 0 17.126-.148 30.91-.148 35.126 0 3.407 2.304 7.398 8.792 6.14C219.37 232.5 256 184.537 256 128.002 256 57.307 198.691 0 128.001 0Z"></path>
                    </svg>
                  </a>
                </div>
              </div>

              <!-- Description -->
              <p class="line-clamp-2 text-sm text-neutral-600 dark:text-neutral-400" data-i18n={`repo.${project.name}.desc`}>
                {project.description}
              </p>

              <!-- Language bar (cuando hay datos de lenguajes) -->
              {project.languages && Object.keys(project.languages).length > 0 && (
                <LanguagesBar languages={project.languages} />
              )}

              <!-- Tags (excluye lenguajes ya mostrados en LanguagesBar) -->
              {(() => {
                const langNames = new Set(Object.keys(project.languages ?? {}));
                const filteredTags = project.tags.filter((tag) => !langNames.has(tag.name));
                return filteredTags.length > 0 ? (
                  <div class="flex items-center flex-wrap gap-1.5 sm:gap-2">
                    {filteredTags.slice(0, 4).map((tag, tagIdx) => {
                      const iconSvg = getTagIcon(tag.name);
                      const uniqueSvg = iconSvg ? scopeSvg(iconSvg, `c${projectIdx}-${tagIdx}`) : "";
                      return (
                      <span class="inline-flex items-center gap-1.5 rounded-[2.5px] border border-neutral-300 bg-neutral-200/50 px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium dark:border-neutral-800 dark:bg-neutral-800/60 dark:text-neutral-300">
                        {iconSvg && (
                          <Fragment set:html={uniqueSvg} />
                        )}
                        <span>{tag.name}</span>
                      </span>
                      );
                    })}
                  </div>
                ) : null;
              })()}

            </div>
          </div>
        </div>
      ))
    }
  </div>
  )}

  <!-- Footer note -->
  {projects.length > 0 && (
      <p class="text-xs text-neutral-400 dark:text-neutral-600 text-right fade-down-section" id="project-count" data-i18n="projects.count" data-i18n-vars={JSON.stringify({ count: projects.length })} style="--delay: 300ms">
        {projects.length} projects in total
      </p>
  )}

</BaseLayout>

<style is:global>
  .hidden-card { display: none !important; }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".card").forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--y", `${e.clientY - rect.top}px`);
      });
    });

    const search = document.getElementById("project-search");
    const cards = document.querySelectorAll("[data-search-name]");
    const count = document.getElementById("project-count");

    if (!search || !cards.length) return;

    function filter(q) {
      q = q.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const name = card.getAttribute("data-search-name") || "";
        const desc = card.getAttribute("data-search-desc") || "";
        const tags = card.getAttribute("data-search-tags") || "";
        const match = !q || name.includes(q) || desc.includes(q) || tags.includes(q);
        if (match) {
          card.classList.remove("hidden-card");
          visible++;
        } else {
          card.classList.add("hidden-card");
        }
      });
      if (count) {
        count.textContent = q
          ? `${visible} of ${cards.length} projects`
          : `${cards.length} projects in total`;
      }
    }

    search.addEventListener("input", () => filter(search.value));
    filter("");
  });
</script>
