---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { experiences } from "@/features/experience/data";

const assetId = (n: number) => String(n + 1).padStart(3, "0");
---

<BaseLayout
  title="Experience"
  description="Career history of Cristhobal Canales — Fullstack Developer from Chile. 5 roles in public institutions and private companies, building web systems, administrative platforms and FiveM scripts."
  canonicalPath="/experience"
>
  <!-- Page header -->
  <section
    class="relative hud-brackets p-5 sm:p-6 hud-bevel"
    style="background: linear-gradient(180deg, rgba(13,18,25,0.85) 0%, rgba(10,14,20,0.7) 100%); border:1px solid rgba(255,184,0,0.25);"
  >
    <nav
      class="flex items-center gap-2 font-mono text-[10px] tracking-[0.2em] uppercase mb-3 text-titanium/45"
      aria-label="Breadcrumb"
    >
      <a
        href="/"
        class="text-arc-cyan hover:text-glow-cyan transition-colors"
        aria-label="Home">~/HOME</a
      >
      <span aria-hidden="true">/</span>
      <span aria-current="page" class="text-stark-gold">DEPLOYMENT_LOG</span>
    </nav>
    <p class="hud-label mb-1">// FILE 03 · CHRONOLOGY</p>
    <h1 class="text-3xl sm:text-4xl text-titanium tracking-[0.08em]">
      DEPLOYMENT <span class="text-glow-cyan">LOG</span>
    </h1>
    <p
      class="mt-3 text-sm text-titanium/75 leading-relaxed border-l-2 border-stark-red/60 pl-3 max-w-2xl"
    >
      The track record. Every problem I was handed, and what I did with it.
    </p>
  </section>

  <!-- Timeline -->
  <ol class="space-y-4">
    {
      experiences.map((exp, index) => {
        const isCurrent = exp.period.toLowerCase().includes("present");
        return (
          <li class="card hud-bevel-sm relative">
            <div class="flex items-center justify-between px-3 sm:px-4 py-1.5 border-b border-stark-gold/20 bg-arc-cyan/[0.04] font-mono text-[9px] tracking-[0.22em] uppercase">
              <span class="text-stark-red flex items-center gap-2">
                LOG #{assetId(index)}
              </span>
              <span class="flex items-center gap-3">
                {isCurrent && (
                  <span class="text-arc-cyan flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-arc-cyan arc-pulse inline-block" />
                    ACTIVE
                  </span>
                )}
                <time class="text-stark-gold/85">{exp.period}</time>
              </span>
            </div>

            <div class="p-4 sm:p-5">
              <h3 class="text-base sm:text-lg text-titanium tracking-[0.06em]">
                {exp.role}
              </h3>
              {exp.companyUrl ? (
                <a
                  href={exp.companyUrl}
                  target="_blank"
                  rel="noopener"
                  class="group/c mt-1 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-[0.18em] text-stark-gold/85 hover:text-stark-gold transition-colors"
                >
                  <span>{exp.company}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    class="duration-150 group-hover/c:translate-x-[1.5px]"
                  >
                    <path d="M7 7h10v10" />
                    <path d="M7 17 17 7" />
                  </svg>
                </a>
              ) : (
                <p class="mt-1 font-mono text-xs uppercase tracking-[0.18em] text-stark-gold/85">
                  {exp.company}
                </p>
              )}
              <p class="mt-3 text-sm text-titanium/75 leading-relaxed border-l-2 border-arc-cyan/40 pl-3">
                {exp.description}
              </p>
            </div>
          </li>
        );
      })
    }
  </ol>

  <!-- Footer note -->
  <p
    class="font-mono text-[10px] tracking-[0.22em] uppercase text-titanium/45 text-right"
  >
    <span class="text-stark-gold">●</span>
    {experiences.length} ENTRIES // ARCHIVE COMPLETE
  </p>

  <style>
    .text-titanium\/45 { color: rgba(232, 232, 232, 0.5); }
    .text-titanium\/75 { color: rgba(232, 232, 232, 0.78); }
    .text-stark-gold { color: var(--color-stark-gold); }
    .text-stark-gold\/85 { color: rgba(255, 184, 0, 0.88); }
    .text-stark-red { color: var(--color-stark-red); }
    .text-arc-cyan { color: var(--color-arc-cyan); }
    .border-stark-gold\/20 { border-color: rgba(255, 184, 0, 0.22); }
    .border-stark-red\/60 { border-color: rgba(225, 13, 26, 0.6); }
    .border-arc-cyan\/40 { border-color: rgba(0, 229, 255, 0.42); }
    .bg-arc-cyan { background-color: var(--color-arc-cyan); }
    .bg-arc-cyan\/\[0\.04\] { background-color: rgba(0, 229, 255, 0.04); }
  </style>
</BaseLayout>
