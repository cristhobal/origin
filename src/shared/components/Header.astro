---
// HUD command bar — STARK INDUSTRIES // OPERATIVE banner.
// No theme toggle: J.A.R.V.I.S. doesn't ship a light mode.
---

<header
  class="sticky top-0 z-50 w-full bg-[#05080c]/90 backdrop-blur-md border-b border-stark-gold/30 relative"
  role="banner"
>
  <!-- Diagnostic strip: thin warning bar across the top -->
  <div class="stark-stripes h-[3px] w-full opacity-60"></div>

  <div
    class="max-w-5xl mx-auto flex items-center justify-between px-4 sm:px-6 py-2.5 sm:py-3"
  >
    <!-- Brand: STARK INDUSTRIES // OPERATIVE -->
    <a
      href="/"
      aria-label="Cristhobal Canales — home"
      class="group flex items-center gap-3 font-mono text-[10px] sm:text-xs tracking-[0.18em] uppercase text-titanium"
    >
      <!-- Hex/arc logo -->
      <span
        class="relative inline-flex items-center justify-center w-6 h-6 sm:w-7 sm:h-7"
        aria-hidden="true"
      >
        <svg viewBox="0 0 32 32" class="w-full h-full" fill="none">
          <polygon
            points="16,2 28,9 28,23 16,30 4,23 4,9"
            stroke="#ffb800"
            stroke-width="1.5"
            fill="rgba(225,13,26,0.12)"
          ></polygon>
          <circle
            cx="16"
            cy="16"
            r="4"
            fill="#00e5ff"
            opacity="0.85"
            class="arc-pulse"></circle>
          <circle cx="16" cy="16" r="1.4" fill="#fff"></circle>
        </svg>
      </span>
      <span class="hidden xs:inline-flex flex-col leading-tight">
        <span class="text-stark-gold/90"
          >STARK INDUSTRIES <span class="text-titanium/40">//</span></span
        >
        <span
          class="text-titanium group-hover:text-glow-gold transition-colors duration-200"
          >OPERATIVE: CANALES, C.</span
        >
      </span>
      <span class="xs:hidden flex-col leading-tight inline-flex">
        <span class="text-stark-gold/90">STARK</span>
        <span class="text-titanium">CANALES, C.</span>
      </span>
    </a>

    <!-- Status + nav: STATUS chip, social comms, no theme toggle -->
    <nav
      aria-label="Status and external comms"
      class="flex items-center gap-2 sm:gap-3"
    >
      <!-- STATUS: ONLINE -->
      <div
        class="hidden sm:inline-flex items-center gap-2 px-2.5 py-1 border border-arc-cyan/40 bg-arc-cyan/5"
        role="status"
        aria-label="System online"
      >
        <span
          class="w-1.5 h-1.5 rounded-full bg-arc-cyan arc-pulse"
          aria-hidden="true"></span>
        <span
          class="font-mono text-[9px] tracking-[0.25em] text-arc-cyan uppercase"
          >ONLINE</span
        >
      </div>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/cristhobal"
        title="LinkedIn // External Channel"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center w-8 h-8 border border-stark-gold/30 hover:border-stark-gold hover:bg-stark-gold/10 hover:shadow-[0_0_12px_rgba(255,184,0,0.45)] transition-all duration-150 text-stark-gold/80 hover:text-stark-gold"
        aria-label="LinkedIn"
      >
        <svg class="h-3.5 w-auto" viewBox="0 0 256 256" fill="currentColor">
          <path
            d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.907 39.907 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186l-.016 67.013ZM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009-.002-12.157 9.851-22.014 22.008-22.016 12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97v122.16ZM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453"
          ></path>
        </svg>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/cristhobal"
        title="GitHub // Repo Access"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center w-8 h-8 border border-stark-gold/30 hover:border-stark-gold hover:bg-stark-gold/10 hover:shadow-[0_0_12px_rgba(255,184,0,0.45)] transition-all duration-150 text-stark-gold/80 hover:text-stark-gold"
        aria-label="GitHub"
      >
        <svg class="h-3.5 w-auto" viewBox="0 0 1024 1024" fill="currentColor">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
            transform="scale(64)"></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  /* xs breakpoint helper for compact device tag */
  @media (min-width: 380px) {
    :global(.xs\:inline-flex) {
      display: inline-flex !important;
    }
    :global(.xs\:hidden) {
      display: none !important;
    }
  }

  .text-titanium {
    color: var(--color-titanium);
  }
  .text-stark-gold {
    color: var(--color-stark-gold);
  }
  .text-arc-cyan {
    color: var(--color-arc-cyan);
  }
  .border-stark-gold\/30 {
    border-color: rgba(255, 184, 0, 0.3);
  }
  .border-arc-cyan\/40 {
    border-color: rgba(0, 229, 255, 0.4);
  }
  .bg-arc-cyan\/5 {
    background-color: rgba(0, 229, 255, 0.05);
  }
  .bg-stark-gold\/10 {
    background-color: rgba(255, 184, 0, 0.1);
  }
  .bg-arc-cyan {
    background-color: var(--color-arc-cyan);
  }
  .text-stark-gold\/80 {
    color: rgba(255, 184, 0, 0.85);
  }
  .text-stark-gold\/90 {
    color: rgba(255, 184, 0, 0.92);
  }
  .text-titanium\/40 {
    color: rgba(232, 232, 232, 0.4);
  }
  .text-titanium\/80 {
    color: rgba(232, 232, 232, 0.85);
  }
</style>
