---
const year = new Date().getFullYear();
---

<footer
  class="mt-12 sm:mt-16 w-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-4 pb-6 sm:pb-8"
  role="contentinfo"
>
  <div class="pt-6">
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-1 text-xs sm:text-sm text-muted-foreground"
    >
      <p class="tracking-tight font-medium">Build. Break. Improve. Patent.</p>
      <p class="opacity-60">&copy; {year} Cristhobal Canales.</p>
    </div>
  </div>
</footer>
